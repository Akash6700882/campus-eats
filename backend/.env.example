APP_NAME=Campus Eats
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=["http://localhost:5173"]

# Database
DATABASE_URL=postgresql+asyncpg://campus_eats:campus_eats@postgres:5432/campus_eats
DATABASE_URL_SYNC=postgresql+psycopg2://campus_eats:campus_eats@postgres:5432/campus_eats
POSTGRES_USER=campus_eats
POSTGRES_PASSWORD=campus_eats
POSTGRES_DB=campus_eats

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Seed admin account
DEFAULT_ADMIN_EMAIL=admin@campuseats.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_PHONE=9999999999

# Razorpay — https://dashboard.razorpay.com/app/keys (use TEST mode keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# Google Maps — https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@campuseats.local

# Notification providers: "console" logs instead of sending (default, no account needed)
SMS_PROVIDER=console
WHATSAPP_PROVIDER=console

# Order pricing defaults (INR)
DELIVERY_CHARGE=15.0
PACKING_CHARGE=5.0
GST_PERCENT=5.0
